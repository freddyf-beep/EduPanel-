# Firebase client - copiar como .env.local y completar
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App Check (reCAPTCHA v3). Clave de SITIO publica que entrega
# Firebase Console > App Check al registrar la app web. Si se deja vacia,
# App Check no se inicializa (la app sigue funcionando sin proteccion).
NEXT_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_KEY=

# Cloud Messaging (FCM). Clave Web Push (VAPID) publica desde
# Configuracion del proyecto > Cloud Messaging > Certificados push web.
# Si se deja vacia, las notificaciones push no se activan.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Cron (Vercel) — secreto para proteger /api/cron/*. Vercel envia
# Authorization: Bearer $CRON_SECRET. Si se deja vacio, el cron responde 401
# (la tarea nocturna queda inactiva). Genera un valor aleatorio largo.
CRON_SECRET=

# Google Drive personal (OAuth / Google Cloud)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_APP_ID=

# Alfa cerrada
# Solo desarrollo local. NUNCA usar true en produccion.
NEXT_PUBLIC_ALLOWLIST_BYPASS=false
ADMIN_EMAIL=udefret34@gmail.com,freddyfiguea@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=udefret34@gmail.com,freddyfiguea@gmail.com

# Firebase Admin - API routes server-side
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Pegar la clave privada completa con saltos escapados (\n), sin comillas adicionales.
FIREBASE_ADMIN_PRIVATE_KEY=

# Proveedores IA
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Modelos Gemini (opcional — sobreescriben los defaults en el codigo)
# GEMINI_FAST_MODEL=gemini-2.5-flash
# GEMINI_LESSON_MODEL=gemini-2.5-pro

# Vertex AI Search (Discovery Engine) — grounding sobre el corpus de curriculum.
# Consume el credito de "GenAI App Builder". Opcional: si falta, pedagogical-search
# usa solo busqueda web. Ver docs/vertex-ai-search-setup.md.
# Usa el access token de la cuenta de servicio de Firebase Admin (no necesita key).
# VERTEX_SEARCH_ENGINE_ID=        # ID del motor/app de busqueda (recomendado)
# VERTEX_SEARCH_DATASTORE_ID=     # alternativa al engine
# VERTEX_SEARCH_PROJECT_ID=       # por defecto FIREBASE_ADMIN_PROJECT_ID
# VERTEX_SEARCH_LOCATION=global   # o "us", "eu"
# VERTEX_SEARCH_COLLECTION=default_collection
