# Firebase client - copiar como .env.local y completar
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Drive personal (OAuth / Google Cloud)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_APP_ID=

# Alfa cerrada
# Solo desarrollo local. NUNCA usar true en produccion.
NEXT_PUBLIC_ALLOWLIST_BYPASS=false
ADMIN_EMAIL=freddyfigueroagea@gmail.com,freddyfiguea@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=freddyfigueroagea@gmail.com,freddyfiguea@gmail.com

# Firebase Admin - API routes server-side
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Pegar la clave privada completa con saltos escapados (\n), sin comillas adicionales.
FIREBASE_ADMIN_PRIVATE_KEY=

# Proveedores IA
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Modelos Gemini (opcional — sobreescriben los defaults en el codigo)
# GEMINI_FAST_MODEL=gemini-2.5-flash
# GEMINI_LESSON_MODEL=gemini-2.5-pro
