# Copia este archivo como .env.backup.local si quieres separar la config de backups.
# Las credenciales Firebase Admin tambien pueden vivir en .env.local.

# Modo de ejecucion del panel/admin:
# - local: el backend dispara el script en esta misma maquina
# - ssh: el backend consulta y dispara un runner remoto por SSH
BACKUP_EXECUTION_TARGET=local
BACKUP_SSH_HOST_ALIAS=mi-servidor-ubuntu
BACKUP_SSH_RUNNER_DIR=/home/tu_usuario/edupanel-backup-runner

# Carpeta local donde se guardan los respaldos.
BACKUP_LOCAL_DIR=backups/firestore

# Si es mayor a 0, elimina respaldos locales antiguos creados por este script.
BACKUP_RETENTION_DAYS=0

# Si es false y NO usas --plain-json-only, elimina el .json local despues de comprimir.
BACKUP_KEEP_PLAIN_JSON=true

# Activa el transporte REST del SDK Admin de Firestore.
# Util si el servidor Ubuntu no puede usar bien gRPC.
FIRESTORE_PREFER_REST=false

# Envio al servidor Ubuntu por SSH/SCP.
BACKUP_REMOTE_ENABLED=false
BACKUP_REMOTE_USER=tu_usuario
BACKUP_REMOTE_HOST=192.168.1.50
BACKUP_REMOTE_PORT=22
BACKUP_REMOTE_DIR=/home/tu_usuario/edupanel-backups/firestore

# Opcional: ruta local de la llave SSH privada.
# BACKUP_REMOTE_IDENTITY_FILE=C:\Users\fredd\.ssh\id_ed25519
